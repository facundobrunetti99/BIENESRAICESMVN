extends ../../layout/index
block contenido 
    div.py-10
        h2.text-4xl.font-extrabold.text-center.text-gray-700 Bienes
            span.font-normal.text-gray-700 Raices
            h2.text-4xl.text-center.font-bold.text-gray-700.mb-10 #{pagina}
    div.mx-auto.max-w-md.bg-gray-300.p-4.rouded-md.-mt-16
        form
             div.bg-gray-200.p-4.rouded-md
               label.block.text-lg.font-bold.text-gray-500(for="nombre") Nombre y Apellido
               input#nombre.w-full.px-3.py-2.border.border-gray-400.rounded-md.placeholder-gray-400(type="text" placeholder="Tu nombre" name="nombre")
               label.block.mt-5.text-lg.font-bold.text-gray-500(for="email") Correo Electronico
               input#email.block.w-full.px-3.py-2.border.border-gray-400.rounded-md.placeholder-gray-400(type="email" placeholder="Tu correo Electronico " name="email")
               label.block.mt-5.mt-5.text-lg.font-bold.text-gray-500(for="password") Cotraseña 
               input#password.py-2.px-3.border.border-gray-400.rounded-md.placeholder-gray-400.w-full(type="password" name="password" placeholder="Tu contraseña") 
               label.block.mt-5.mt-5.text-lg.font-bold.text-gray-500(for="repeat_password") Repetir Cotraseña 
               input#password.py-2.px-3.border.border-gray-400.rounded-md.placeholder-gray-400.w-full(type="password" name="repeat_password" placeholder="Tu contraseña") 
               input.py-2.px-3.mt-5.border.border-gray-400.rounded-md.placeholder-gray-400.w-full(type="submit" value="Enviar")